# Epic account
# Required.
EPIC_EMAIL=
EPIC_PASSWORD=

# Provider
# Required.
# Supported by this branch: glm, deepseek, gemini
LLM_PROVIDER=glm

# GLM
# Required when LLM_PROVIDER=glm.
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.6v

# DeepSeek V4
# Required when LLM_PROVIDER=deepseek.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING_ENABLED=false
DEEPSEEK_REASONING_EFFORT=high

# Gemini / AiHubMix
# Required when LLM_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://aihubmix.com
GEMINI_MODEL=gemini-2.5-pro

# OpenAI / GPT
# Only use this section with a code version that includes the OpenAI provider.
# OPENAI_MODEL must support image input.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1-mini

# Advanced model overrides
# Optional. Leave empty unless different models are required for different captcha tasks.
CHALLENGE_CLASSIFIER_MODEL=
IMAGE_CLASSIFIER_MODEL=
SPATIAL_POINT_REASONER_MODEL=
SPATIAL_PATH_REASONER_MODEL=

# Browser runtime
# Supported values: auto, camoufox, playwright
BROWSER_BACKEND=auto

# Runtime
ENABLE_APSCHEDULER=false
