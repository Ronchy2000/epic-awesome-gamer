# Epic account
EPIC_EMAIL=xxxx@qq.com
EPIC_PASSWORD=mypassword

# LLM provider
# Supported values: gemini, glm, deepseek
LLM_PROVIDER=glm

# GLM (recommended)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.6v

# DeepSeek V4 (optional)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING_ENABLED=false
DEEPSEEK_REASONING_EFFORT=high

# Gemini / AiHubMix (optional)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://aihubmix.com
GEMINI_MODEL=gemini-2.5-pro

# Optional model overrides
# Leave these empty to follow GLM_MODEL, DEEPSEEK_MODEL, or GEMINI_MODEL automatically.
# Example for GLM: glm-4.6v
# Example for DeepSeek V4: deepseek-v4-flash
# Example for Gemini / AiHubMix: gemini-2.5-pro
CHALLENGE_CLASSIFIER_MODEL=
IMAGE_CLASSIFIER_MODEL=
SPATIAL_POINT_REASONER_MODEL=
SPATIAL_PATH_REASONER_MODEL=

# Browser runtime
# Supported values: auto, camoufox, playwright
BROWSER_BACKEND=auto

# Local one-shot debugging
ENABLE_APSCHEDULER=false
