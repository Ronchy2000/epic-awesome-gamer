# Epic account
# If a value contains $, \, #, or `, wrap it in single quotes in local .env files.
EPIC_EMAIL=your_epic_email@example.com
EPIC_PASSWORD='your_epic_password'

# --------------------------------------------------------------------
# Preferred protocol-first LLM configuration
# --------------------------------------------------------------------
# Choose one preset:
# - gemini
# - aihubmix
# - openai
# - deepseek
# - glm
# - ollama
# - minimax
# - xiaomi_mimo
# - custom_openai_compatible
LLM_PRESET=glm

# Optional explicit protocol family.
# Normally leave this empty and let the preset decide:
# - google_genai
# - openai_compatible
LLM_PROTOCOL=

# Canonical provider fields.
# These are the preferred fields for new setups.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Optional knobs for presets that support them.
LLM_THINKING_ENABLED=false
LLM_REASONING_EFFORT=

# --------------------------------------------------------------------
# Preset quick reference
# --------------------------------------------------------------------
# gemini:
#   LLM_PRESET=gemini
#   LLM_API_KEY=your_gemini_key
#   LLM_BASE_URL=
#   LLM_MODEL=gemini-2.5-pro
#
# aihubmix:
#   LLM_PRESET=aihubmix
#   LLM_API_KEY=your_aihubmix_key
#   LLM_BASE_URL=https://aihubmix.com
#   LLM_MODEL=gemini-2.5-pro
#
# openai:
#   LLM_PRESET=openai
#   LLM_API_KEY=your_openai_key
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4.1-mini
#
# deepseek:
#   LLM_PRESET=deepseek
#   LLM_API_KEY=your_deepseek_key
#   LLM_BASE_URL=https://api.deepseek.com
#   LLM_MODEL=deepseek-v4-pro
#   LLM_THINKING_ENABLED=false
#   LLM_REASONING_EFFORT=high
#
# glm:
#   LLM_PRESET=glm
#   LLM_API_KEY=your_glm_key
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   LLM_MODEL=glm-4.6v
#
# ollama:
#   LLM_PRESET=ollama
#   LLM_API_KEY=
#   LLM_BASE_URL=http://127.0.0.1:11434/v1
#   LLM_MODEL=qwen3-vl:8b
#
# minimax:
#   LLM_PRESET=minimax
#   LLM_API_KEY=your_minimax_key
#   LLM_BASE_URL=https://api.minimaxi.com/v1
#   LLM_MODEL=your_vision_capable_model
#
# xiaomi_mimo:
#   LLM_PRESET=xiaomi_mimo
#   LLM_API_KEY=your_mimo_key
#   LLM_BASE_URL=fill_from_official_console
#   LLM_MODEL=fill_from_official_console
#
# custom_openai_compatible:
#   LLM_PRESET=custom_openai_compatible
#   LLM_API_KEY=optional_or_required_by_your_gateway
#   LLM_BASE_URL=https://your-gateway.example.com/v1
#   LLM_MODEL=your_model_name

# --------------------------------------------------------------------
# Legacy compatibility fields
# --------------------------------------------------------------------
# These still work, but new setups should prefer the canonical fields above.

# Legacy alias for LLM_PRESET
LLM_PROVIDER=

# Gemini / AiHubMix legacy fields
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-pro

# GLM legacy fields
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.6v

# OpenAI legacy fields
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# DeepSeek legacy fields
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_ENABLED=false
DEEPSEEK_REASONING_EFFORT=high

# --------------------------------------------------------------------
# Optional per-task model overrides
# --------------------------------------------------------------------
# Leave these empty to follow the resolved default model automatically.
CHALLENGE_CLASSIFIER_MODEL=
IMAGE_CLASSIFIER_MODEL=
SPATIAL_POINT_REASONER_MODEL=
SPATIAL_PATH_REASONER_MODEL=

# Browser runtime
# Supported values: auto, camoufox, playwright
BROWSER_BACKEND=auto

# Local one-shot debugging
ENABLE_APSCHEDULER=false
